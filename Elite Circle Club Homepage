            <a href="#" onclick="showTerms(); return false;"><i class="fas fa-file-contract"></i> Terms</a>
        </div>
    </div>

    <!-- WhatsApp Float -->
    <div class="whatsapp-float">
        <a href="https://wa.me/18184056632" class="whatsapp-link" target="_blank">
            <i class="fab fa-whatsapp"></i>
        </a>
    </div>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-content">
                <div class="price-badge">
                    <i class="fas fa-gem"></i> ELITE CIRCLE
                </div>
                <h1>Elite Digital Transformation for Visionary Founders</h1>
                <p>Join the exclusive circle of entrepreneurs leveraging cutting-edge AI, automation, and digital strategy. Limited to 50 members worldwide.</p>
                
