                    <a href="#contact" class="btn">
                        <i class="fas fa-lock"></i> Secure Membership
                    </a>
                    <a href="#value" class="btn btn-outline">
                        <i class="fas fa-play-circle"></i> Watch Demo
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Value Proposition -->
    <section id="value" style="padding: 4rem 0;">
        <div class="container">
            <div class="section-title">
                <h2>How You Get Profit?</h2>
                <p>Strategic investment delivering 5-10x ROI through exclusive access and premium tools.</p>
            </div>
            
            <div class="grid-3">
                <div class="card fade-in">
                    <div class="card-icon"><i class="fas fa-user-shield"></i></div>
                    <h3>Exclusive Member Circle</h3>
                    <p>Limited to 50 entrepreneurs. Direct access to core team and priority support.</p>
                </div>
                
                <div class="card fade-in">
                    <div class="card-icon"><i class="fas fa-brain"></i></div>
                    <h3>AI-Powered Automation</h3>
                    <p>Proprietary AI tools saving 30+ hours per week on operations.</p>
                </div>
                
                <div class="card fade-in">
                    <div class="card-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>Revenue Growth Engine</h3>
                    <p>Members average $3,200+ additional monthly revenue within 90 days.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="services" style="padding: 4rem 0; background: var(--darker);">
        <div class="container">
            <div class="section-title">
                <h2>Premium Services</h2>
                <p>Everything you need to build, automate, and scale your digital presence.</p>
            </div>
            
            <div class="grid-4" id="servicesGrid">
                <!-- Services will be loaded dynamically -->
            </div>
        </div>
    </section>

    <!-- Portfolio -->
    <section id="portfolio" style="padding: 4rem 0;">
        <div class="container">
            <div class="section-title">
                <h2>Portfolio Showcase</h2>
                <p>Transformative results delivered for elite members.</p>
            </div>
            
            <div class="portfolio-grid" id="portfolioGrid">
                <!-- Portfolio items will be loaded dynamically -->
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section id="testimonials" style="padding: 4rem 0; background: var(--darker);">
        <div class="container">
            <div class="section-title">
                <h2>Member Experiences</h2>
                <p>Hear from entrepreneurs who transformed their businesses.</p>
            </div>
            
            <div class="testimonial-slider">
                <div class="testimonial-track" id="testimonialTrack">
                    <!-- Testimonials will be loaded dynamically -->
                </div>
                
                <div class="slider-controls">
                    <button class="slider-btn" id="prevBtn"><i class="fas fa-chevron-left"></i></button>
                    <button class="slider-btn" id="nextBtn"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" style="padding: 4rem 0;">
        <div class="container">
            <div class="section-title">
                <h2>Begin Your Transformation</h2>
                <p>Limited memberships available. Schedule a consultation.</p>
            </div>
            
            <div class="contact-grid">
                <div>
                    <h3 style="margin-bottom: 2rem;">Contact Information</h3>
                    
                    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
                        <div style="width: 48px; height: 48px; background: rgba(139,92,246,0.1); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--accent-light);">
