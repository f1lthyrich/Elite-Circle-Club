    <!-- Success Modal -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--accent), #7C3AED); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2rem;">
                <i class="fas fa-check"></i>
            </div>
            
            <h2 style="color: var(--accent-light); margin-bottom: 1rem;">Application Submitted!</h2>
            
            <div style="background: rgba(139,92,246,0.1); padding: 1.5rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; text-align: left;">
                <h4 style="color: var(--accent-light); margin-bottom: 1rem;">What Happens Now:</h4>
                <ol style="margin-left: 1.5rem; color: var(--text-secondary);">
                    <li>Check WhatsApp for my message</li>
                    <li>I'll text you within 60 minutes</li>
                    <li>Schedule strategy call</li>
                    <li>Get started within 24 hours</li>
                </ol>
            </div>
            
            <a href="https://wa.me/18184056632" class="btn" style="width: 100%; margin-bottom: 1rem; background: #25D366;" target="_blank">
                <i class="fab fa-whatsapp"></i> Open WhatsApp Now
            </a>
            
            <button class="btn btn-outline" style="width: 100%;" onclick="closeModal()">
                Close & Continue
            </button>
        </div>
    </div>

    <script>
        // Data Objects
        const services = [
            { icon: 'fa-code', title: 'Premium Website Development', desc: 'Custom-coded, high-performance websites with advanced animations and SEO.' },
            { icon: 'fa-film', title: 'AI Video & Animation', desc: 'Professional motion graphics and AI-generated content.' },
            { icon: 'fa-robot', title: 'Business Automation', desc: 'Custom AI workflows, chatbots, and automated marketing funnels.' },
            { icon: 'fa-paint-brush', title: 'Brand & UI/UX Design', desc: 'Complete visual identity systems and user interface designs.' },
            { icon: 'fa-lightbulb', title: 'Business Problem-Solving', desc: 'Strategic consulting to optimize processes and drive growth.' },
            { icon: 'fa-rocket', title: 'Online Business Startup', desc: 'From concept to launch with monetization strategies.' },
            { icon: 'fa-network-wired', title: 'Affiliate Marketing', desc: 'Complete program setup and management.' },
            { icon: 'fa-graduation-cap', title: 'Affiliate Training', desc: 'Step-by-step training to build your affiliate empire.' }
        ];

        const portfolio = [
            { img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71', title: 'AI Analytics Dashboard', desc: 'Real-time business intelligence platform' },
            { img: 'https://images.unsplash.com/photo-1558655146-9f40138edfeb', title: 'Luxury E-commerce', desc: '3D product visualization with AI recommendations' },
            { img: 'https://images.unsplash.com/photo-1552664730-d307ca884978', title: 'Fintech Mobile App', desc: 'Banking with AI financial advisor' },
            { img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f', title: 'Marketing Automation', desc: 'AI-powered customer journey' }
        ];

        const testimonials = [
            { initials: 'SR', name: 'Sarah Reynolds', role: 'E-commerce Founder', text: 'The AI automations saved me 25+ hours monthly. Built a $12K/month passive income stream.' },
            { initials: 'MJ', name: 'Michael Johnson', role: 'Management Consultant', text: 'Premium website elevated my perceived value, allowing 40% rate increase.' },
            { initials: 'AK', name: 'Alex Kim', role: 'Digital Marketer', text: 'Affiliate training helped me earn $8,000+ monthly through strategic partnerships.' }
        ];

        const termsContent = `
            <h2 style="margin-top: 2rem;"><span style="color: var(--accent);">1.</span> Services</h2>
            <p>Elite Circle Club provides digital services including website creation, AI-powered content, marketing strategies, and consulting.</p>
            
            <h2><span style="color: var(--accent);">2.</span> Payment & Fees</h2>
            <ul style="list-style: none; padding-left: 1rem;">
                <li style="margin-bottom: 0.5rem;">• Services provided on one-time payment basis</li>
                <li style="margin-bottom: 0.5rem;">• Pricing disclosed during consultation</li>
                <li style="margin-bottom: 0.5rem;">• Late payment may result in service suspension</li>
            </ul>
            
            <h2><span style="color: var(--accent);">3.</span> Client Responsibilities</h2>
            <p>Clients agree to provide accurate information, necessary access, and timely feedback.</p>
            
            <h2><span style="color: var(--accent);">4.</span> Intellectual Property</h2>
            <p>All materials remain property of Elite Circle Club until full payment is received.</p>
            
            <h2><span style="color: var(--accent);">5.</span> Limitation of Liability</h2>
            <p>We make no guarantees regarding financial success. Liability limited to amount paid for services.</p>
            
            <h2><span style="color: var(--accent);">6.</span> Governing Law</h2>
            <p>Terms governed by laws of California, USA. Disputes resolved in Los Angeles jurisdiction.</p>
        `;

        // Load data
        function loadData() {
            // Services
            const servicesGrid = document.getElementById('servicesGrid');
            servicesGrid.innerHTML = services.map(service => `
                <div class="card fade-in">
                    <div class="card-icon"><i class="fas ${service.icon}"></i></div>
                    <h3>${service.title}</h3>
                    <p>${service.desc}</p>
                </div>
            `).join('');

            // Portfolio
            const portfolioGrid = document.getElementById('portfolioGrid');
            portfolioGrid.innerHTML = portfolio.map(item => `
                <div class="portfolio-item fade-in">
                    <img src="${item.img}?auto=format&fit=crop&w=800&q=80" alt="${item.title}" loading="lazy">
                    <div class="portfolio-overlay">
                        <h3>${item.title}</h3>
                        <p>${item.desc}</p>
                    </div>
                </div>
            `).join('');

            // Testimonials
            const testimonialTrack = document.getElementById('testimonialTrack');
            testimonialTrack.innerHTML = testimonials.map(t => `
                <div class="testimonial-slide">
                    <div class="testimonial-card">
                        <div class="testimonial-content" style="margin-bottom: 1.5rem; position: relative; padding-left: 1.5rem;">
                            <div style="position: absolute; left: 0; top: -10px; font-size: 3rem; color: var(--accent); opacity: 0.3;">"</div>
                            <p>${t.text}</p>
                        </div>
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--accent), #7C3AED); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600;">${t.initials}</div>
                            <div>
                                <h4>${t.name}</h4>
                                <p style="color: var(--text-secondary);">${t.role}</p>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');

            // Terms
            document.getElementById('termsContent').innerHTML = termsContent;

            // Interest options
            const interestSelect = document.getElementById('interest');
            const options = [
                'Premium Website Development',
                'AI Video & Animation',
                'Business Automation',
                'Brand & UI/UX Design',
                'Business Problem-Solving',
                'Online Business Startup',
                'Affiliate Marketing Program',
                'Affiliate Training Academy',
                'Make First $1000 On Phone',
                'AI Analytics Dashboard',
                'Custom Interest'
            ];
            interestSelect.innerHTML = '<option value="">Select interest</option>' + 
                options.map(opt => `<option value="${opt}">${opt}</option>`).join('');
        }

        // Loading screen
        window.addEventListener('load', () => {
            setTimeout(() => {
                document.getElementById('loading').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('loading').style.display = 'none';
                }, 500);
            }, 800);
            
            loadData();
            initIntersectionObserver();
        });

        // Quick nav toggle
        const quickNavBtn = document.getElementById('quickNavBtn');
        const quickNav = document.getElementById('quickNav');

        quickNavBtn.addEventListener('click', () => {
            quickNavBtn.classList.toggle('active');
            quickNav.classList.toggle('active');
        });

        document.addEventListener('click', (e) => {
            if (!quickNav.contains(e.target) && !quickNavBtn.contains(e.target)) {
                quickNavBtn.classList.remove('active');
                quickNav.classList.remove('active');
            }
        });

        // Testimonial slider
        let currentIndex = 0;
        const track = document.getElementById('testimonialTrack');
        const slides = document.querySelectorAll('.testimonial-slide');
        const slideCount = slides.length;

        function updateSlider() {
            track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }

        document.getElementById('nextBtn')?.addEventListener('click', () => {
            currentIndex = (currentIndex + 1) % slideCount;
            updateSlider();
        });

        document.getElementById('prevBtn')?.addEventListener('click', () => {
            currentIndex = (currentIndex - 1 + slideCount) % slideCount;
            updateSlider();
        });

        // Auto advance
        setInterval(() => {
            currentIndex = (currentIndex + 1) % slideCount;
            updateSlider();
        }, 5000);

        // Custom interest field
        document.getElementById('interest')?.addEventListener('change', function() {
            const field = document.getElementById('customInterestField');
            field.style.display = this.value === 'Custom Interest' ? 'block' : 'none';
        });

        // Form submission
        document.getElementById('contactForm')?.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const name = document.getElementById('name').value;
            const phone = document.getElementById('phone').value;
            const interest = document.getElementById('interest').value;
            const message = document.getElementById('message').value;
            
            const whatsappMsg = `*NEW APPLICATION*%0A%0A*Name:* ${name}%0A*Phone:* ${phone}%0A*Interest:* ${interest}%0A*Message:* ${message}%0A%0A*Time:* ${new Date().toLocaleString()}`;
            
            document.getElementById('successModal').classList.add('active');
            
            setTimeout(() => {
                window.open(`https://wa.me/18184056632?text=${whatsappMsg}`, '_blank');
            }, 2000);
            
            e.target.reset();
            document.getElementById('customInterestField').style.display = 'none';
        });

        // Modal functions
        window.closeModal = function() {
            document.getElementById('successModal').classList.remove('active');
        };

        // Terms functions
        window.showTerms = function() {
            const terms = document.getElementById('termsSection');
            terms.style.display = 'block';
            setTimeout(() => {
                terms.scrollIntoView({ behavior: 'smooth' });
            }, 100);
            quickNavBtn.classList.remove('active');
            quickNav.classList.remove('active');
        };

        window.hideTerms = function() {
            document.getElementById('termsSection').style.display = 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

        // Intersection Observer for animations
        function initIntersectionObserver() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
        }

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Header scroll effect
        const header = document.querySelector('.header');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 100) {
                header.style.background = 'rgba(10,10,15,0.98)';
                header.style.backdropFilter = 'blur(20px)';
            } else {
                header.style.background = 'rgba(10,10,15,0.95)';
                header.style.backdropFilter = 'blur(10px)';
            }
        });
    </script>
</body>
