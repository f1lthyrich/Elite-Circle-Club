                            <textarea id="customInterest" rows="2"></textarea>
                        </div>
                        
                        <div class="form-group">
                            <label>Your Goals</label>
                            <textarea id="message" rows="4" required></textarea>
                        </div>
                        
                        <button type="submit" class="btn" style="width: 100%;">
                            <i class="fas fa-paper-plane"></i> Request Consultation
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Terms Section -->
    <section class="terms-section" id="termsSection">
        <div class="container">
            <div class="terms-card">
                <h1 style="margin-bottom: 1rem;">Terms & Conditions</h1>
                <div style="background: rgba(139,92,246,0.1); display: inline-block; padding: 0.5rem 1rem; border-radius: 50px; margin-bottom: 2rem;">
                    <i class="fas fa-calendar-check" style="margin-right: 0.5rem;"></i> Effective Date: 2026
                </div>
                
                <div id="termsContent">
                    <!-- Terms content will be loaded dynamically -->
